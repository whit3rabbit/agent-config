surface: skills
agent: codebuddy
scenario: uninstall_final_skill_removes_empty_ledger

uninstall_result:
Ok(
    UninstallReport {
        removed: [
            "[ROOT]/.codebuddy/skills/golden-skill",
        ],
        patched: [],
        restored: [],
        not_installed: false,
    },
)
status:
Ok(
    StatusReport {
        target: Skill {
            name: "golden-skill",
        },
        status: Absent,
        config_path: Some(
            "[ROOT]/.codebuddy/skills/golden-skill",
        ),
        ledger_path: Some(
            "[ROOT]/.codebuddy/skills/.agent-config-skills.json",
        ),
        files: [
            Missing {
                path: "[ROOT]/.codebuddy/skills/golden-skill",
            },
            Missing {
                path: "[ROOT]/.codebuddy/skills/golden-skill/SKILL.md",
            },
        ],
        warnings: [],
    },
)
validation:
Ok(
    ValidationReport {
        target: Skill {
            integration_id: "codebuddy",
            scope: Local(
                "[ROOT]",
            ),
            name: "golden-skill",
            owner: "golden-owner",
        },
        ok: true,
        issues: [],
        suggested_actions: [
            NoAction,
        ],
    },
)

ROOT tree:
directories:
- .codebuddy
- .codebuddy/skills

HOME tree:
<empty>
