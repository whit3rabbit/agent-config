surface: mcp
agent: codex
scenario: existing_other_owner_same_name

install_result:
Err(
    NotOwnedByCaller {
        kind: "mcp server",
        name: "golden-server",
        expected: "golden-owner",
        actual: Some(
            "other-owner",
        ),
    },
)
status:
Ok(
    StatusReport {
        target: Mcp {
            name: "golden-server",
        },
        status: InstalledOtherOwner {
            owner: "other-owner",
        },
        config_path: Some(
            "[ROOT]/.codex/config.toml",
        ),
        ledger_path: Some(
            "[ROOT]/.codex/.ai-hooker-mcp.json",
        ),
        files: [
            Exists {
                path: "[ROOT]/.codex/config.toml",
            },
            Exists {
                path: "[ROOT]/.codex/.ai-hooker-mcp.json",
            },
        ],
        warnings: [],
    },
)
validation:
Ok(
    ValidationReport {
        target: Mcp {
            integration_id: "codex",
            scope: Local(
                "[ROOT]",
            ),
            name: "golden-server",
            owner: "golden-owner",
        },
        ok: false,
        issues: [
            OwnerMismatch {
                expected: "golden-owner",
                actual: Some(
                    "other-owner",
                ),
                path: Some(
                    "[ROOT]/.codex/.ai-hooker-mcp.json",
                ),
            },
        ],
        suggested_actions: [
            UninstallWithOwner,
        ],
    },
)

ROOT tree:
directories:
- .codex
files:
- .codex/.ai-hooker-mcp.json
  content:
```text
{
  "entries": {
    "golden-server": {
      "owner": "other-owner"
    }
  },
  "version": 1
}
```
- .codex/config.toml
  content:
```text
[mcp_servers.golden-server]
command = "npx"
args = ["-y", "@example/server"]
```

