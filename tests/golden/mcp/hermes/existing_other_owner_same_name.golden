surface: mcp
agent: hermes
scenario: existing_other_owner_same_name

install_result:
Err(
    NotOwnedByCaller {
        kind: "mcp server",
        name: "golden-server",
        expected: "golden-owner",
        actual: Some(
            "other-owner",
        ),
    },
)
status:
Ok(
    StatusReport {
        target: Mcp {
            name: "golden-server",
        },
        status: InstalledOtherOwner {
            owner: "other-owner",
        },
        config_path: Some(
            "[HOME]/.hermes/config.yaml",
        ),
        ledger_path: Some(
            "[HOME]/.hermes/.agent-config-mcp.json",
        ),
        files: [
            Exists {
                path: "[HOME]/.hermes/config.yaml",
            },
            Exists {
                path: "[HOME]/.hermes/.agent-config-mcp.json",
            },
        ],
        warnings: [],
    },
)
validation:
Ok(
    ValidationReport {
        target: Mcp {
            integration_id: "hermes",
            scope: Global,
            name: "golden-server",
            owner: "golden-owner",
        },
        ok: false,
        issues: [
            OwnerMismatch {
                expected: "golden-owner",
                actual: Some(
                    "other-owner",
                ),
                path: Some(
                    "[HOME]/.hermes/.agent-config-mcp.json",
                ),
            },
        ],
        suggested_actions: [
            UninstallWithOwner,
        ],
    },
)

ROOT tree:
<empty>

HOME tree:
directories:
- .hermes
files:
- .hermes/.agent-config-mcp.json
  content:
```text
{
  "entries": {
    "golden-server": {
      "content_hash": "de73436d65e5d173e50b0a75ebd36bc753c2281d77b04050a84202439c0173ec",
      "owner": "other-owner"
    }
  },
  "version": 2
}
```
- .hermes/config.yaml
  content:
```text
