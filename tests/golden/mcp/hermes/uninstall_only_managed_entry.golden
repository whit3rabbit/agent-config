surface: mcp
agent: hermes
scenario: uninstall_only_managed_entry

uninstall_result:
Ok(
    UninstallReport {
        removed: [
            "[HOME]/.hermes/config.yaml",
        ],
        patched: [],
        restored: [],
        not_installed: false,
    },
)
status:
Ok(
    StatusReport {
        target: Mcp {
            name: "golden-server",
        },
        status: Absent,
        config_path: Some(
            "[HOME]/.hermes/config.yaml",
        ),
        ledger_path: Some(
            "[HOME]/.hermes/.ai-hooker-mcp.json",
        ),
        files: [
            Missing {
                path: "[HOME]/.hermes/config.yaml",
            },
            Missing {
                path: "[HOME]/.hermes/.ai-hooker-mcp.json",
            },
        ],
        warnings: [],
    },
)
validation:
Ok(
    ValidationReport {
        target: Mcp {
            integration_id: "hermes",
            scope: Global,
            name: "golden-server",
            owner: "golden-owner",
        },
        ok: true,
        issues: [],
        suggested_actions: [
            NoAction,
        ],
    },
)

ROOT tree:
<empty>

HOME tree:
directories:
- .hermes
