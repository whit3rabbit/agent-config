surface: mcp
agent: hermes
scenario: existing_user_installed_same_name_no_ledger

install_result:
Err(
    NotOwnedByCaller {
        kind: "mcp server",
        name: "golden-server",
        expected: "golden-owner",
        actual: None,
    },
)
status:
Ok(
    StatusReport {
        target: Mcp {
            name: "golden-server",
        },
        status: PresentUnowned,
        config_path: Some(
            "[HOME]/.hermes/config.yaml",
        ),
        ledger_path: Some(
            "[HOME]/.hermes/.agent-config-mcp.json",
        ),
        files: [
            Exists {
                path: "[HOME]/.hermes/config.yaml",
            },
            Missing {
                path: "[HOME]/.hermes/.agent-config-mcp.json",
            },
        ],
        warnings: [],
    },
)
validation:
Ok(
    ValidationReport {
        target: Mcp {
            integration_id: "hermes",
            scope: Global,
            name: "golden-server",
            owner: "golden-owner",
        },
        ok: false,
        issues: [
            ConfigOnly {
                path: "[HOME]/.hermes/config.yaml",
            },
        ],
        suggested_actions: [
            RemoveConfigEntry,
        ],
    },
)

ROOT tree:
<empty>

HOME tree:
directories:
- .hermes
files:
- .hermes/config.yaml
  content:
```text
mcp_servers:
  golden-server:
    command: npx
    args:
    - -y
    - '@example/server'
```
