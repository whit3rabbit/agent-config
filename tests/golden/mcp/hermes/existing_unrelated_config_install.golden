surface: mcp
agent: hermes
scenario: existing_unrelated_config_install

install_result:
Ok(
    InstallReport {
        created: [],
        patched: [
            "[HOME]/.hermes/config.yaml",
        ],
        backed_up: [
            "[HOME]/.hermes/config.yaml.bak",
        ],
        already_installed: false,
    },
)
status:
Ok(
    StatusReport {
        target: Mcp {
            name: "golden-server",
        },
        status: InstalledOwned {
            owner: "golden-owner",
        },
        config_path: Some(
            "[HOME]/.hermes/config.yaml",
        ),
        ledger_path: Some(
            "[HOME]/.hermes/.ai-hooker-mcp.json",
        ),
        files: [
            Exists {
                path: "[HOME]/.hermes/config.yaml",
            },
            Exists {
                path: "[HOME]/.hermes/.ai-hooker-mcp.json",
            },
        ],
        warnings: [],
    },
)
validation:
Ok(
    ValidationReport {
        target: Mcp {
            integration_id: "hermes",
            scope: Global,
            name: "golden-server",
            owner: "golden-owner",
        },
        ok: false,
        issues: [
            BackupCollision {
                path: "[HOME]/.hermes/config.yaml.bak",
            },
        ],
        suggested_actions: [
            RestoreBackup,
        ],
    },
)

