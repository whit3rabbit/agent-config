surface: mcp
agent: openclaw
scenario: existing_other_owner_same_name

install_result:
Err(
    NotOwnedByCaller {
        kind: "mcp server",
        name: "golden-server",
        expected: "golden-owner",
        actual: Some(
            "other-owner",
        ),
    },
)
status:
Ok(
    StatusReport {
        target: Mcp {
            name: "golden-server",
        },
        status: InstalledOtherOwner {
            owner: "other-owner",
        },
        config_path: Some(
            "[HOME]/.openclaw/openclaw.json",
        ),
        ledger_path: Some(
            "[HOME]/.openclaw/.agent-config-mcp.json",
        ),
        files: [
            Exists {
                path: "[HOME]/.openclaw/openclaw.json",
            },
            Exists {
                path: "[HOME]/.openclaw/.agent-config-mcp.json",
            },
        ],
        warnings: [],
    },
)
validation:
Ok(
    ValidationReport {
        target: Mcp {
            integration_id: "openclaw",
            scope: Global,
            name: "golden-server",
            owner: "golden-owner",
        },
        ok: false,
        issues: [
            OwnerMismatch {
                expected: "golden-owner",
                actual: Some(
                    "other-owner",
                ),
                path: Some(
                    "[HOME]/.openclaw/.agent-config-mcp.json",
                ),
            },
        ],
        suggested_actions: [
            UninstallWithOwner,
        ],
    },
)

